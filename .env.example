# ----------------------------------------------------------------
# Davi Rapid - variables de entorno para Dokploy
# Copiar a .env (o definir en el panel) y completar valores reales.
# ----------------------------------------------------------------

# Modo de la app
DEBUG=false

# URL pública completa (obligatoria en producción por HostHeaderMiddleware)
APP_FULL_BASE_URL=https://admin.davirapid.com

# Cadena aleatoria de al menos 32 caracteres
# Generar con: openssl rand -hex 32
SECURITY_SALT=__GENERAR_CON_openssl_rand_hex_32__

# DSN de la base de datos (contenedor externo de Dokploy)
# Formato: mysql://USER:PASS@HOST:3306/DB?encoding=utf8mb4&timezone=UTC
DATABASE_URL=mysql://davirapid:cambiar@db-host:3306/davirapid?encoding=utf8mb4&timezone=UTC
